import math
import cmath

try:
    # Reading input coefficients
    a, b, c = map(float, input().split())
    
    # Calculating the discriminant
    d = b**2 - 4*a*c
    
    if d > 0:
        # Real and different roots
        root1 = (-b + math.sqrt(d)) / (2 * a)
        root2 = (-b - math.sqrt(d)) / (2 * a)
        print(f"root1 = {root1:.2f}")
        print(f"root2 = {root2:.2f}")
        
    elif d == 0:
        # Real and same roots
        root1 = -b / (2 * a)
        print(f"root1 = root2 = {root1:.2f}")
        
    else:
        # Imaginary roots
        real_part = -b / (2 * a)
        imag_part = math.sqrt(abs(d)) / (2 * a)
        print(f"root1 = {real_part:.2f}+{imag_part:.2f}i")
        print(f"root2 = {real_part:.2f}-{imag_part:.2f}i")

except ValueError:
    pass

